{
  "name": "pdf-book-reader",
  "version": "0.1.99",
  "description": "PDF book reader core + React bindings with deep-link page state and per-page audio mapping.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "react": [
        "dist/react.d.ts"
      ],
      "react/web": [
        "dist/react-web.d.ts"
      ],
      "react/native": [
        "dist/react-native.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./react/web": {
      "types": "./react/web.d.ts",
      "browser": "./react/web.js",
      "import": "./react/web.js",
      "require": "./dist/react-web.cjs"
    },
    "./react/web.js": {
      "types": "./react/web.d.ts",
      "default": "./react/web.js"
    },
    "./react/native": {
      "types": "./react/native.d.ts",
      "react-native": "./react/native.js",
      "import": "./react/native.js",
      "require": "./dist/react-native.cjs"
    },
    "./react/native.js": {
      "types": "./react/native.d.ts",
      "react-native": "./react/native.js",
      "default": "./react/native.js"
    }
  },
  "files": [
    "dist",
    "react"
  ],
  "dependencies": {
    "expo-linking": "~8.0.8"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "pdf",
    "reader",
    "flipbook",
    "audio-sync",
    "react"
  ],
  "peerDependencies": {
    "@expo/vector-icons": ">=14",
    "expo-audio": ">=1",
    "expo-linking": ">=7",
    "expo-file-system": ">=17",
    "expo-secure-store": ">=12",
    "expo-sharing": ">=11",
    "pdfjs-dist": ">=4",
    "react": ">=18",
    "react-native": ">=0.72",
    "react-native-static-server": ">=0.5",
    "react-native-webview": ">=13"
  },
  "peerDependenciesMeta": {
    "@expo/vector-icons": {
      "optional": true
    },
    "expo-linking": {
      "optional": true
    },
    "expo-audio": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-webview": {
      "optional": true
    },
    "expo-file-system": {
      "optional": true
    },
    "expo-secure-store": {
      "optional": true
    },
    "expo-sharing": {
      "optional": true
    },
    "react-native-static-server": {
      "optional": true
    },
    "pdfjs-dist": {
      "optional": true
    }
  },
  "devDependencies": {
    "@expo/vector-icons": "~15.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.2.4",
    "typescript": "^5.6.3"
  }
}
